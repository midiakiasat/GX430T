#!/usr/bin/env bash
set -euo pipefail

ROOT="${GX430T_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
PY="${GX430T_PYTHON:-python3}"
PORT="${GX430T_PORT:-9430}"

case "${1:-help}" in
  start|serve)
    cd "$ROOT"
    exec "$PY" host-service/gx430t_host.py serve --port "$PORT" --open
    ;;
  start-bg)
    cd "$ROOT"
    mkdir -p "$HOME/.gx430t"
    nohup "$PY" host-service/gx430t_host.py serve --port "$PORT" > "$HOME/.gx430t/host.log" 2>&1 &
    echo "GX430T_HOST_PID=$!"
    echo "URL=http://127.0.0.1:$PORT"
    ;;
  stop)
    lsof -ti tcp:"$PORT" | xargs kill -9 >/dev/null 2>&1 || true
    echo "GX430T_HOST_STOPPED=true"
    ;;
  open)
    open "http://127.0.0.1:$PORT" || true
    ;;
  upload)
    shift
    cd "$ROOT"
    exec "$PY" host-service/gx430t_host.py upload "$@"
    ;;
  status)
    cd "$ROOT"
    exec "$PY" host-service/gx430t_host.py status
    ;;
  print-next|print-all|clear)
    cd "$ROOT"
    exec "$PY" host-service/gx430t_host.py "$1"
    ;;
  health)
    curl -fsS "http://127.0.0.1:$PORT/api/health"
    ;;
  *)
    cat <<EOF
GX430T Mac Control v0.2.9

Commands:
  gx430tctl start       Start local upload/queue/print UI
  gx430tctl start-bg    Start in background
  gx430tctl open        Open browser UI
  gx430tctl upload FILE Add CSV/XLSX to ordered print queue
  gx430tctl status      Show queue status
  gx430tctl print-next  Print next queued label
  gx430tctl print-all   Print all queued labels in order
  gx430tctl clear       Clear queued labels
  gx430tctl stop        Stop local server

UI:
  http://127.0.0.1:$PORT
EOF
    ;;
esac
